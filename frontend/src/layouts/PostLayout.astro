---
const { frontmatter } = Astro.props;
---

<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>{frontmatter.title}</title>
</head>

<body class="bg-gray-50 text-gray-900 max-w-3xl mx-auto px-4 py-10">

<h1 class="text-4xl font-bold mb-2">
    {frontmatter.title}
</h1>

<p class="text-gray-500 mb-8">
    {frontmatter.pubDate.toDateString()}
</p>

<article class="prose">
    <slot />
</article>

</body>
</html>