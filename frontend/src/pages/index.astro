---
import Layout from "../layouts/MainLayout.astro";

import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import BlogPreview from "../components/BlogPreview.astro";
import ResearchPreview from "../components/ResearchPreview.astro";
import FieldSlideshow from "../components/FieldSlideshow.astro";
import Footer from "../components/Footer.astro";
---

<Layout>

    <!-- Navigation -->
    <Navbar />

    <main>

        <!-- Hero Section -->
        <section id="home">
            <Hero />
        </section>

        <!-- Blog Preview -->
        <section id="blog" class="section-container">
            <BlogPreview />

            <div class="section-footer">
                <a href="/blog" class="section-link">
                    View all blog posts →
                </a>
            </div>
        </section>

        <!-- Research Preview -->
        <section id="research" class="section-container">
            <ResearchPreview />

            <div class="section-footer">
                <a href="/projects" class="section-link">
                    View all research projects →
                </a>
            </div>
        </section>

        <!-- Field Slideshow -->
        <section id="fields">
            <FieldSlideshow />
        </section>

    </main>

    <!-- Footer -->
    <Footer />

</Layout>

<style>

    main{
        display:flex;
        flex-direction:column;
        gap:100px;
    }

    /* Section width control */

    .section-container{
        max-width:1100px;
        margin:auto;
        padding:0 20px;
        width:100%;
    }

    /* Footer link under previews */

    .section-footer{
        margin-top:30px;
        text-align:right;
    }

    /* Link styling */

    .section-link{
        font-size:.95rem;
        font-weight:500;

        text-decoration:none;

        color:#2563eb;

        transition:opacity .2s ease;
    }

    .section-link:hover{
        opacity:.75;
    }

</style>