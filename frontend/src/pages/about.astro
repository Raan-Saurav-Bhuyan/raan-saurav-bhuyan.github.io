---
import Layout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout>

    <Navbar />

    <main>

        <section class="max-w-3xl mx-auto py-24 px-6">

            <h1 class="text-4xl font-bold mb-10 text-center">
                About
            </h1>

            <div class="space-y-6 text-gray-700 leading-relaxed">

                <p>
                    Hello! I'm <strong>Raan Saurav Bhuyan</strong>.
                </p>

                <p>
                    This site showcases my work in research, software engineering,
                    and technical writing. My interests span artificial intelligence,
                    distributed systems, and scientific computing.
                </p>

                <p>
                    I enjoy exploring complex systems, building tools,
                    and writing about technical ideas.
                </p>

                <p>
                    This portfolio highlights my research projects,
                    blog posts, and technical explorations.
                </p>

            </div>

        </section>

    </main>

    <Footer />

</Layout>