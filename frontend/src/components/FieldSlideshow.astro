---
const slides = [
    {
        title: "Artificial Intelligence",
        description:
            "Machine learning, neural networks, and intelligent systems that learn from data.",
        image: "/images/ai.jpg",
    },
    {
        title: "Robotics",
        description:
            "Autonomous machines interacting with the physical world through sensors and control systems.",
        image: "/images/robotics.jpg",
    },
    {
        title: "Cybersecurity",
        description:
            "Designing secure systems and protecting digital infrastructure from emerging threats.",
        image: "/images/cybersecurity.jpg",
    },
    {
        title: "Distributed Systems",
        description:
            "Large-scale computing architectures enabling resilient and scalable infrastructure.",
        image: "/images/distributed.jpg",
    },
    {
        title: "Scientific Computing",
        description:
            "High-performance computing used to accelerate scientific discovery.",
        image: "/images/hpc.jpg",
    },
];
---

<section class="slideshow">

    {slides.map((slide) => (
            <div class="slide">

                <div
                        class="background"
                        style={`background-image: url(${slide.image});`}
                ></div>

                <div class="overlay"></div>

                <div class="content">
                    <h2>{slide.title}</h2>
                    <p>{slide.description}</p>
                </div>

            </div>
    ))}

</section>

<style>

    .slideshow{
        position:relative;
        height:500vh;
        width:100%;
    }

    /* Each slide sticks during scrolling */

    .slide{
        position:sticky;
        top:0;
        height:100vh;
        display:flex;
        align-items:center;
        justify-content:center;
        overflow:hidden;
    }

    /* Background image */

    .background{
        position:absolute;
        inset:0;
        background-size:cover;
        background-position:center;

        transform:scale(1.15);
        animation:parallax linear forwards;
        animation-timeline:view();
    }

    /* Dark gradient overlay */

    .overlay{
        position:absolute;
        inset:0;

        background:linear-gradient(
                to bottom,
                rgba(0,0,0,.35),
                rgba(0,0,0,.75)
        );
    }

    /* Slide text */

    .content{
        position:relative;
        z-index:2;

        text-align:center;
        color:white;

        max-width:700px;
        padding:20px;
    }

    .content h2{
        font-size:3rem;
        margin-bottom:1rem;
        letter-spacing:.5px;
    }

    .content p{
        font-size:1.25rem;
        line-height:1.6;
        opacity:.9;
    }

    /* Parallax motion */

    @keyframes parallax{

        from{
            transform:scale(1.15) translateY(-8%);
        }

        to{
            transform:scale(1.15) translateY(8%);
        }

    }

    /* Responsive */

    @media (max-width:768px){

        .content h2{
            font-size:2.2rem;
        }

        .content p{
            font-size:1rem;
        }

    }

</style>