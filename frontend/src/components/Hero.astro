<section class="hero">

    <!-- Animated gradient overlay -->
    <div class="gradient"></div>

    <!-- Navigation bar -->
    <nav class="navbar">

        <div class="logo">
            <a href="/">Portfolio</a>
        </div>

        <div class="nav-links">
            <a href="#research">Research</a>
            <a href="#projects">Projects</a>
            <a href="/blog">Blog</a>
            <a href="#contact">Contact</a>
        </div>

        <div class="social">

            <a
                    href="https://github.com/yourusername"
                    target="_blank"
                    rel="noopener"
                    aria-label="GitHub"
            >
                <img src="/icons/github.svg" alt="GitHub">
            </a>

            <a
                    href="https://linkedin.com/in/yourusername"
                    target="_blank"
                    rel="noopener"
                    aria-label="LinkedIn"
            >
                <img src="/icons/linkedin.svg" alt="LinkedIn">
            </a>

        </div>

    </nav>

    <!-- Hero content -->

    <div class="hero-content">

        <h1>Research & Technology</h1>

        <p>
            Exploring artificial intelligence, distributed systems,
            and computational science.
        </p>

        <div class="hero-buttons">

            <a href="#projects" class="primary-btn">
                View Projects
            </a>

            <a href="/blog" class="secondary-btn">
                Read Blog
            </a>

        </div>

    </div>

</section>

<style>

    /* HERO SECTION */

    .hero{
        position:relative;
        height:100vh;
        width:100%;

        display:flex;
        flex-direction:column;

        background:
                url("/images/hero.jpg")
                center / cover
                no-repeat;

        color:white;
    }

    /* Animated gradient */

    .gradient{
        position:absolute;
        inset:0;

        background:
                radial-gradient(circle at 20% 30%, rgba(0,140,255,.35), transparent),
                radial-gradient(circle at 80% 70%, rgba(255,0,150,.25), transparent),
                rgba(0,0,0,.55);

        animation:gradientShift 12s infinite alternate;
    }

    @keyframes gradientShift{

        from{
            filter:hue-rotate(0deg);
        }

        to{
            filter:hue-rotate(40deg);
        }

    }

    /* NAVBAR */

    .navbar{
        position:relative;
        z-index:10;

        display:flex;
        justify-content:space-between;
        align-items:center;

        padding:20px 40px;

        backdrop-filter:blur(10px);

        background:rgba(255,255,255,.08);

        border-bottom:1px solid rgba(255,255,255,.15);
    }

    /* Logo */

    .logo a{
        font-size:1.2rem;
        font-weight:600;
        text-decoration:none;
        color:white;
    }

    /* Navigation links */

    .nav-links{
        display:flex;
        gap:24px;
    }

    .nav-links a{
        color:white;
        text-decoration:none;
        font-size:.95rem;
        opacity:.9;
        transition:opacity .2s;
    }

    .nav-links a:hover{
        opacity:1;
    }

    /* Social icons */

    .social{
        display:flex;
        gap:16px;
    }

    .social img{
        width:22px;
        height:22px;
        filter:invert(1);
        opacity:.9;
        transition:opacity .2s;
    }

    .social img:hover{
        opacity:1;
    }

    /* HERO CONTENT */

    .hero-content{
        position:relative;
        z-index:2;

        margin:auto;
        text-align:center;

        max-width:700px;
        padding:20px;
    }

    .hero-content h1{
        font-size:4rem;
        margin-bottom:1rem;
        letter-spacing:.5px;
    }

    .hero-content p{
        font-size:1.35rem;
        opacity:.9;
    }

    /* HERO BUTTONS */

    .hero-buttons{
        margin-top:30px;
        display:flex;
        justify-content:center;
        gap:16px;
    }

    /* Primary button */

    .primary-btn{
        padding:12px 26px;

        border-radius:30px;

        background:white;
        color:black;

        text-decoration:none;

        font-weight:600;

        transition:transform .2s, box-shadow .2s;
    }

    .primary-btn:hover{
        transform:translateY(-2px);
        box-shadow:0 10px 25px rgba(0,0,0,.25);
    }

    /* Secondary button */

    .secondary-btn{
        padding:12px 26px;

        border-radius:30px;

        border:1px solid rgba(255,255,255,.6);

        color:white;
        text-decoration:none;

        transition:background .2s;
    }

    .secondary-btn:hover{
        background:rgba(255,255,255,.1);
    }

    /* MOBILE */

    @media (max-width:768px){

        .navbar{
            padding:16px 20px;
        }

        .nav-links{
            display:none;
        }

        .hero-content h1{
            font-size:2.6rem;
        }

        .hero-content p{
            font-size:1.1rem;
        }

    }

</style>